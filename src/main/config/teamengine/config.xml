<!-- Unpack the *-ctl-scripts.zip archive in the TE_BASE/scripts directory -->
<!-- Add this entry to TE_BASE/config.xml (//organization/standard) -->
<organization>
  <name>OGC</name>
  <standard>
    <name>Web Coverage Processing Standard (WCPS)</name>
    <version>
      <name>${spec-version}</name>
      <suite>
        <namespace-uri>http://www.opengis.net/cite/wcps11</namespace-uri>
        <prefix>tns</prefix>
        <local-name>ets-wcps11-${version}</local-name>
        <title>WCPS 1.1 Conformance Test Suite</title>
        <description>Describe scope of testing.</description>
      </suite>
      <revision>
        <name>${project.version}</name>
        <status>Beta</status>
        <sources>
          <source>wcps11/${spec-version}/ctl</source>
        </sources>
        <webdir>wcps11/${spec-version}/site</webdir>
      </revision>
    </version>
  </standard>
</organization>
